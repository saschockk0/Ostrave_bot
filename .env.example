# Токен бота от @BotFather
BOT_TOKEN=123456:ABC-DEF...

# ID чата менеджеров, куда падают заявки (для групп обычно отрицательное число, напр. -1001234567890).
# В этом же чате работают команды /leads, /lead и кнопки смены статуса.
# Можно указать топик прямо здесь через слэш: -1001234567890/127 (chat_id/thread_id).
MANAGERS_CHAT_ID=-1001234567890

# (Необязательно) ID топика в группе менеджеров, если включены темы (forum).
# Заявки будут падать именно в этот топик. Узнать значение: добавьте бота в группу
# и вызовите /chatinfo в нужном топике — он подскажет MANAGERS_CHAT_ID и MANAGERS_TOPIC_ID.
# Пусто или 0 — слать в основной чат / тему «General».
# Если задан здесь — имеет приоритет над «/127» в MANAGERS_CHAT_ID.
MANAGERS_TOPIC_ID=127

# Файл локальной БД заявок (источник правды). Можно не менять.
DB_PATH=leads.db

# (Необязательно) Файл персистентного FSM-хранилища — недозаполненные диалоги
# (заявки, калькулятор) переживают перезапуск бота. Можно не менять.
FSM_DB_PATH=fsm.db

# (Необязательно) HTTPS-ссылка на Mini App-афишу из webapp/.
# Если оставить пустым — заявку оформляют прямо в чате, кнопка афиши не
# показывается ни в меню, ни на кнопке «Меню» у поля ввода.
# Локально можно прокинуть туннель: cloudflared tunnel --url http://localhost:5173
WEBAPP_URL=

# (Необязательно) Ссылка на канал проекта (t.me/…). Показывается в приветствии
# /start и кнопкой «📣 Наш канал» на экране после отправки заявки.
# Пусто — ссылка нигде не показывается.
CHANNEL_URL=https://t.me/ostrovrave

# (Необязательно) Порт локального приёма заявок из афиши (services/webapi.py):
# из кнопки «Меню» sendData не работает, поэтому форма шлёт заявку POST-ом, а
# наружу этот порт отдаёт nginx (deploy/nginx-afisha.conf). По умолчанию 8081,
# когда задан WEBAPP_URL. 0 — выключить приём.
WEBAPP_API_PORT=
WEBAPP_API_HOST=127.0.0.1

# (Необязательно) Зеркалирование заявок в Google Sheets.
# ID Google-таблицы (из её URL: docs.google.com/spreadsheets/d/<GSHEET_ID>/edit)
GSHEET_ID=

# Путь к JSON-ключу сервис-аккаунта Google
GOOGLE_CREDS_PATH=creds.json

# Название листа в таблице (по умолчанию первый лист)
GSHEET_WORKSHEET=Заявки

# (Необязательно) Логирование. Бот пишет в консоль и в ротируемый файл bot.log.
# LOG_LEVEL=INFO          # DEBUG/INFO/WARNING/ERROR
# LOG_FILE=bot.log        # путь к файлу лога
# LOG_MAX_BYTES=5242880   # размер файла до ротации (по умолчанию 5 МБ)
# LOG_BACKUP_COUNT=5      # сколько бэкапов хранить (bot.log.1 … bot.log.5)
